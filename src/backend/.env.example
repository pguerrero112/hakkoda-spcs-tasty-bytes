# ── Snowflake connection ────────────────────────────────────────────────────
# Account identifier format: <locator>.<region>
# Find yours: SELECT CURRENT_ACCOUNT(), CURRENT_REGION(); in Snowsight
# Example: VEB81086.us-east-1
SNOWFLAKE_ACCOUNT=your_account.your_region

# Find your exact username: SELECT CURRENT_USER(); in Snowsight
SNOWFLAKE_USERNAME=YOUR_SNOWFLAKE_USERNAME

SNOWFLAKE_ROLE=TASTY_APP_ADMIN_ROLE__[user]
SNOWFLAKE_WAREHOUSE=TASTY_APP_WAREHOUSE__[user]
SNOWFLAKE_DATABASE=FROSTBYTE_TASTY_BYTES__[user]
SNOWFLAKE_SCHEMA=APP

# ── Keypair Authentication ───────────────────────────────────────────────────
# Generate keys:
#   openssl genrsa 2048 | openssl pkcs8 -topk8 -inform PEM -out rsa_key.p8 -nocrypt
#   openssl rsa -in rsa_key.p8 -pubout -out rsa_key.pub
# Register in Snowflake:
#   ALTER USER YOUR_USERNAME SET RSA_PUBLIC_KEY='<contents of rsa_key.pub>';
SNOWFLAKE_PRIVATE_KEY_PATH=/absolute/path/to/rsa_key.p8

# ── Auth ─────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_SECRET=replace_with_random_string
REFRESH_TOKEN_SECRET=replace_with_another_random_string

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# ── Validation mode ──────────────────────────────────────────────────────────
# Dev = no auth (local testing) | Snowflake = SPCS OAuth
CLIENT_VALIDATION=Dev