# ── Snowflake connection ────────────────────────────────────────────────────
# For local development only. In SPCS these are injected automatically.
SNOWFLAKE_ACCOUNT=your_account_identifier
SNOWFLAKE_USERNAME=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_ROLE=TASTY_APP_ADMIN_ROLE_[user]
SNOWFLAKE_WAREHOUSE=TASTY_APP_WAREHOUSE_[user]
SNOWFLAKE_DATABASE=FROSTBYTE_TASTY_BYTES_[user]
SNOWFLAKE_SCHEMA=APP

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
ACCESS_TOKEN_SECRET=replace_with_random_string
REFRESH_TOKEN_SECRET=replace_with_another_random_string

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# ── Validation mode ──────────────────────────────────────────────────────────
# Dev      = no auth required (local testing)
# Snowflake = use Sf-Context-Current-User header (SPCS deployment)
CLIENT_VALIDATION=Dev
