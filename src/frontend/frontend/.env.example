# For local development — points to the local backend
REACT_APP_BACKEND_URL=http://localhost:3000

# For SPCS deployment — calls go through the NGINX router prefix
# REACT_APP_BACKEND_URL=/api

# Validation mode — must match the backend setting
# Dev      = no login form, auto-login as franchise 1
# Snowflake = use SPCS OAuth authorize endpoint
REACT_APP_CLIENT_VALIDATION=Dev
